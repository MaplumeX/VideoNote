# VideoNote Environment Configuration

# OpenAI API Key (fallback for ASR and LLM if their own keys are not set)
OPENAI_API_KEY=sk-...

# ASR (transcription) Configuration
# ASR_PROVIDER=openai    # openai (default) or siliconflow
# ASR_API_KEY=            # defaults to OPENAI_API_KEY
# ASR_API_BASE=https://api.openai.com/v1
# ASR_MODEL=whisper-1    # e.g. FunAudioLLM/SenseVoiceSmall for siliconflow

# LLM (note generation) Configuration
# LLM_API_KEY=           # defaults to OPENAI_API_KEY
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# yt-dlp proxy (for accessing YouTube etc.)
# YT_DLP_PROXY=http://127.0.0.1:7890

# Upload directory (optional, defaults to /tmp/videonote_uploads)
# UPLOAD_DIR=/tmp/videonote_uploads

# Max upload size in MB (optional, defaults to 500)
# MAX_UPLOAD_SIZE_MB=500
