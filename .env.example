# VideoNote Environment Configuration

# OpenAI API Key (required for Whisper ASR + LLM note generation)
OPENAI_API_KEY=sk-...

# LLM API Base URL (optional, defaults to OpenAI)
# LLM_API_BASE=https://api.openai.com/v1

# LLM Model (optional, defaults to gpt-4o)
# LLM_MODEL=gpt-4o

# Upload directory (optional, defaults to /tmp/videonote_uploads)
# UPLOAD_DIR=/tmp/videonote_uploads

# Max upload size in MB (optional, defaults to 500)
# MAX_UPLOAD_SIZE_MB=500
